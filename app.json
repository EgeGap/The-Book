{
  "expo": {
    "name": "SMC Journal",
    "slug": "smc-trading-journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "smcjournal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smcjournal.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.smcjournal.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "SMC Journal needs access to your photos so you can attach before/after chart screenshots to a trade.",
          "cameraPermission": "SMC Journal needs camera access so you can snap a chart screenshot for a trade."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "febb072d-c827-4d61-9a3d-07d8ce90ec75"
      }
    }
  }
}
